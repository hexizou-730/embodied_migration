# Copy this file to .env and fill in one provider's key.

# Provider options: openrouter or deepseek.
# Default is openrouter.
EM_LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=your_openrouter_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override the default model.
# Available on OpenRouter: anthropic/claude-sonnet-4.5, anthropic/claude-opus-4.5,
# openai/gpt-4o, google/gemini-2.5-pro, deepseek/deepseek-chat, ...
# DeepSeek direct API: deepseek-v4-pro, deepseek-v4-flash
# EM_MODEL=anthropic/claude-sonnet-4.5

# Optional: bound maximum completion tokens for cost control.
# EM_MAX_TOKENS=8192

# DeepSeek V4-Pro defaults to thinking mode at the API level. This project
# disables it by default so complete adapter modules fit in the output budget.
# EM_DEEPSEEK_THINKING=disabled
